# Copy this file to .env and fill in real values.
# These are loaded automatically by electron-vite in dev mode.
# Never commit .env — it is listed in .gitignore.

# Anthropic API key — used by the resume tailoring feature.
# If set here, the app will use this key without requiring you to enter it
# via the Settings UI on every fresh dev run.
ANTHROPIC_API_KEY=sk-ant-...
