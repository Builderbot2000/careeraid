{
  "name": "careeraid",
  "version": "1.2.74",
  "description": "Local-first job hunting desktop app",
  "author": "Kevin Tang <kevintang1118@outlook.com>",
  "main": "out/main/index.js",
  "typstVersion": "0.14.2",
  "scripts": {
    "dev": "node scripts/build-adapters.mjs && electron-vite dev",
    "build": "electron-vite build && node scripts/build-adapters.mjs",
    "build:adapters": "node scripts/build-adapters.mjs",
    "preview": "electron-vite preview",
    "build:dist": "electron-vite build && node scripts/build-adapters.mjs && electron-builder",
    "download:typst": "node scripts/download-typst.mjs",
    "postinstall": "electron-rebuild -f -w better-sqlite3 && node scripts/download-typst.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test:unit": "vitest run",
    "test:e2e": "npm run build && playwright test --config tests/playwright.config.ts",
    "test:e2e:headed": "npm run build && playwright test --config tests/playwright.config.ts --headed",
    "test:e2e:grep": "npm run build && playwright test --config tests/playwright.config.ts -g",
    "render:sdlc": "node docs/render-diagram.js docs/AISDLC_diagram.md"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "better-sqlite3": "^12.0.0",
    "cheerio": "^1.0.0",
    "electron-updater": "^6.8.0",
    "node-fetch": "^2.7.0",
    "nunjucks": "^3.2.4",
    "playwright": "^1.59.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.11",
    "@types/nunjucks": "^3.2.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.careeraid.app",
    "productName": "CareerAid",
    "publish": {
      "provider": "github"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "templates/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.bin/**/*",
      "!node_modules/**/CHANGELOG.md",
      "!node_modules/**/{test,tests,spec,specs,__tests__}/**",
      "!node_modules/**/*.{md,txt,map}"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "extraResources": [
        {
          "from": "bin/typst-darwin-x64",
          "to": "typst-darwin-x64"
        },
        {
          "from": "bin/typst-darwin-arm64",
          "to": "typst-darwin-arm64"
        }
      ],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "extraResources": [
        {
          "from": "bin/typst-win32-x64.exe",
          "to": "typst.exe"
        }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "linux": {
      "extraResources": [
        {
          "from": "bin/typst-linux-x64",
          "to": "typst"
        }
      ],
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    },
    "asarUnpack": [
      "out/adapters/**/*"
    ]
  }
}
